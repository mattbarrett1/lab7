<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quotes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body class="bg-light">

    <div class="container py-4">

        <nav class="mb-3">
            <a href="/" class="btn btn-outline-secondary btn-sm">← Back to Search</a>
        </nav>
        <h1 class="text-center mb-4">
            <%= heading %>
        </h1>

        <% if (rows.length===0) { %>
            <div class="alert alert-warning text-center">No quotes found.</div>
            <% } %>

                <% for (let i of rows) { %>
                    <div class="card mb-3">
                        <div class="card-body">
                            <p class="fs-5 fst-italic">"<%= i.quote %>"</p>
                            <p class="text-end mb-0">
                                <strong>
                                    <a class="authorNames" href="#" authorId="<%= i.authorId %>">
                                        <%= i.firstName %>
                                            <%= i.lastName %>
                                    </a>
                                </strong>
                            </p>
                        </div>
                    </div>
                    <% } %>

    </div>
   <!--creating modal window----> 
    <dialog id="authorModal">
        <div id="authorInfo">
            <h1 id="authorName"></h1>
            <img id="authorPicture" width = 300>
            <br>
            <button id="closeModal">Close</button>
        </div>
    </dialog>
    <script src="/js/quotes.js"></script>
</body>

</html>