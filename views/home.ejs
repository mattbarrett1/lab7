<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quote Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>


    <body class="bg-light">

        <div class="container py-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Search by Keyword</h5>
                    <form id="searchByKeywordForm" action="/searchByKeyword" method="GET" class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Keyword</label>
                            <input type="text" name="keyword" class="form-control" placeholder="e.g. life">
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary">Search</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Search by Author</h5>
                    <%= %>
                        <form action="/searchByAuthor" method="GET" class="row g-2 align-items-end">
                            <div class="col-auto">
                                <label class="form-label">Author</label>
                                <select name="authorId" class="form-select">
                                    <% for (let a of authors) { %>
                                        <option value="<%= a.authorId %>">
                                            <%= a.firstName %>
                                                <%= a.lastName %>
                                        </option>
                                        <% } %>
                                </select>
                            </div>
                            <div class="col-auto">
                                <button class="btn btn-primary">Search</button>
                            </div>
                        </form>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Search by Gender</h5>
                    <form action="/searchByGender" method="GET" class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Gender</label>
                            <select name="gender" class="form-select">
                                <option value="M">Male</option>
                                <option value="F">Female</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary">Search</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Search by Category</h5>
                    <form action="/searchByCategory" method="GET" class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Author</label>
                                <select name="categoryId" class="form-select">
                                    <% for (let i of categories) { %>
                                        <option value="<%= i.category %>">
                                            <%= i.category %>
                                        </option>
                                        <% } %>
                                </select>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary">Search</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Search by Likes</h5>
                    <form action="/searchByLikes" method="GET" class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Minimum</label>
                            <input type="text" name="minimum" class="form-control" placeholder="0">
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Maximum</label>
                            <input type="text" name="maximum" class="form-control" placeholder="100">
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-primary">Search</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div>
            <a href="/newQuote">Add Quote</a>
        </div>
        <div>
            <a href="/newAuthor">Add Author</a>
        </div>

        <script>
            document.querySelector("#searchByKeywordForm").addEventListener("submit", validateKeywordForm);
            function validateKeywordForm() {
                let keyword = document.querySelector("input[name=keyword]").value;
                if (keyword.length <3) {
                    alert("keyword must be at least 3 characters");
                    event.preventDefault(); //prevents the form submission
                }
            }
        </script>
    </body>

</html>